{
  "name": "@dmv-eats/mobile",
  "version": "0.1.0",
  "description": "DMV Eats mobile app (React Native + Expo)",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:all": "eas build --platform all",
    "submit": "eas submit --platform all",
    "test": "jest",
    "test:e2e": "detox test e2e --configuration ios.sim.debug --cleanup",
    "build:e2e": "detox build-framework-cache && detox build-app-cache --configuration ios.sim.debug",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~55.0.0",
    "expo-router": "~3.5.0",
    "expo-font": "~12.0.0",
    "expo-constants": "~16.0.0",
    "expo-device": "~5.0.0",
    "expo-notifications": "~0.28.0",
    "expo-location": "~17.0.0",
    "expo-image": "~1.12.0",
    "expo-av": "~14.0.0",
    "expo-screen-orientation": "~7.0.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-screens": "~4.0.0",
    "react-native-safe-area-context": "^4.8.2",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/bottom-tabs": "^6.1.5",
    "@react-navigation/native-stack": "^6.12.0",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@rnmapbox/maps": "^10.2.10",
    "react-map-gl": "^7.1.5",
    "nativewind": "^4.0.1",
    "zustand": "^4.4.6",
    "@tanstack/react-query": "^5.28.0",
    "@trpc/client": "^11.8.1",
    "@trpc/react-query": "^11.8.1",
    "@clerk/clerk-react-native": "^0.42.0",
    "react-i18next": "^13.5.0",
    "i18next": "^23.7.6",
    "expo-localization": "~15.0.0",
    "zod": "^3.22.4",
    "superjson": "^2.2.1",
    "axios": "^1.6.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.7.2",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.3.2",
    "@testing-library/jest-native": "^5.4.3",
    "detox": "^20.16.1",
    "detox-cli": "^20.16.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
