{
  "name": "@dmv-eats/backend",
  "version": "0.1.0",
  "description": "DMV Eats backend API (Fastify + tRPC)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader tsx ./src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "import:restaurants": "node --loader tsx ./src/jobs/import-restaurants.ts",
    "import:test": "node --loader tsx ./src/jobs/import-restaurants.ts --limit 100"
  },
  "dependencies": {
    "fastify": "^5.7.4",
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "@fastify/sse": "^1.2.0",
    "@trpc/server": "^11.8.1",
    "@trpc/client": "^11.8.1",
    "@t3-oss/env-nextjs": "^0.9.2",
    "zod": "^3.22.4",
    "@openai/sdk": "^4.26.1",
    "@supabase/supabase-js": "^2.41.2",
    "@pinecone-database/pinecone": "^1.1.0",
    "@mapbox/mapbox-sdk": "^0.15.4",
    "stripe": "^14.10.0",
    "redis": "^4.6.13",
    "node-cron": "^3.0.2",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "@clerk/backend": "^0.42.0",
    "axios": "^1.6.5"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prettier": "^3.1.0",
    "prisma": "^5.15.0",
    "@prisma/client": "^5.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
